{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Bash(pwd)",
      "Bash(ls)",
      "Bash(ls -la)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(pnpm install)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm test*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm gen:types)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git stash*)",
      "Bash(git worktree *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.development.local)",
      "Read(./.env.test)",
      "Read(./.env.test.local)",
      "Read(./.env.production)",
      "Read(./.env.production.local)",
      "Read(./.env.staging)",
      "Read(./.env.staging.local)",
      "Read(./.env.preview)",
      "Read(./.env.preview.local)",
      "Read(./.env.*.local)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.development)",
      "Read(./**/.env.development.local)",
      "Read(./**/.env.test)",
      "Read(./**/.env.test.local)",
      "Read(./**/.env.production)",
      "Read(./**/.env.production.local)",
      "Read(./**/.env.staging)",
      "Read(./**/.env.staging.local)",
      "Read(./**/.env.preview)",
      "Read(./**/.env.preview.local)",
      "Read(./**/.env.*.local)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./**/*.pem)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --mirror*)",
      "Bash(git push --all*)",
      "Bash(git push * +main*)",
      "Bash(git push * +master*)",
      "Bash(git push * +refs/heads/main*)",
      "Bash(git push * +refs/heads/master*)",
      "Bash(git push * main*)",
      "Bash(git push * master*)",
      "Bash(sudo *)",
      "Bash(chmod -R 777*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/auto-format.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/block-env-writes.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/block-main-push.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/block-bash-secrets.sh\""
          }
        ]
      }
    ]
  }
}
